#!/usr/bin/env lua

local config_dir = os.getenv("CONFIG_DIR")
package.path = package.path
  .. ";" .. config_dir .. "/?.lua"
  .. ";" .. config_dir .. "/?/init.lua"
package.cpath = package.cpath
  .. ";" .. os.getenv("HOME") .. "/.local/share/sketchybar_lua/?.so"

sbar = require("sketchybar")

-- Start the C helper for CPU/memory monitoring
sbar.exec("killall helper 2>/dev/null; (cd " .. config_dir .. "/helper && make -s 2>/dev/null); "
  .. config_dir .. "/helper/helper com.cato.helper > /dev/null 2>&1")

sbar.begin_config()
require("init")
sbar.hotload(true)
sbar.end_config()

sbar.event_loop()
